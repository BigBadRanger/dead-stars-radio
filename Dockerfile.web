FROM node:24-alpine AS builder
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY lib/api-spec/package.json ./lib/api-spec/
COPY artifacts/dead-stars-radio/package.json ./artifacts/dead-stars-radio/

RUN pnpm install --frozen-lockfile

COPY tsconfig.json tsconfig.base.json ./
COPY lib/ ./lib/
COPY artifacts/dead-stars-radio/ ./artifacts/dead-stars-radio/

# Build the static site
RUN pnpm --filter @workspace/dead-stars-radio run build

# ── Serve with nginx ───────────────────────────────────────────────
FROM nginx:alpine AS runtime

COPY --from=builder /app/artifacts/dead-stars-radio/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
